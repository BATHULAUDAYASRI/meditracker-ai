# Copy to .env and fill in values

# Database (SQLite default; use PostgreSQL in production)
DATABASE_URL=sqlite:///./meditracker.db

# OpenAI (chatbot + report analysis)
OPENAI_API_KEY=
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# JWT signing (generate a long random string for production)
SECRET_KEY=change-me

# Mental health chat subscription gate (true = require DB flag chat_subscription_active)
CHAT_SUBSCRIPTION_REQUIRED=false

# Optional pharmacy partner integration
PHARMACY_PARTNER_BASE_URL=
